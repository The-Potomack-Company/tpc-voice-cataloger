{
  "mode": "yolo",
  "granularity": "comprehensive",
  "parallelization": true,
  "commit_docs": true,
  "model_profile": "balanced",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "pattern_mapper": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "tdd_mode": true,
    "code_review": true,
    "code_review_depth": "deep",
    "ui_review": true,
    "auto_advance": true,
    "skip_discuss": false,
    "use_worktrees": true,
    "research_before_questions": true,
    "_auto_chain_active": false
  },
  "review": {
    "models": {
      "codex": "codex exec -m gpt-5.5"
    }
  },
  "intel": {
    "enabled": true
  },
  "graphify": {
    "enabled": true
  },
  "git": {
    "branching_strategy": "milestone",
    "create_tag": true
  },
  "hooks": {
    "context_warnings": true
  },
  "model_overrides": {
    "gsd-planner": "claude-opus-4-8",
    "gsd-executor": "claude-sonnet-4-6",
    "gsd-debugger": "claude-fable-5",
    "gsd-code-reviewer": "claude-sonnet-4-6",
    "gsd-phase-researcher": "claude-sonnet-4-6",
    "gsd-project-researcher": "claude-sonnet-4-6",
    "gsd-verifier": "claude-sonnet-4-6",
    "gsd-plan-checker": "claude-sonnet-4-6",
    "gsd-integration-checker": "claude-sonnet-4-6",
    "gsd-codebase-mapper": "claude-haiku-4-5",
    "gsd-doc-writer": "claude-haiku-4-5"
  }
}
